# Vision API endpoint, e.g. OpenAI-compatible /v1/chat/completions
VISION_API_URL=https://your-vision-endpoint.example.com/v1/chat/completions
# Keep secret, bridge startup log will only print detected=True/False
VISION_API_KEY=your_api_key_here
# Must be a model with image/vision capability
VISION_MODEL=your_vision_model_here
