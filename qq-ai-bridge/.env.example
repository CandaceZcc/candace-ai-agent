# Preferred location: qq-ai-bridge/.env
# Fallback location also supported: ../.env (repo root)
# Vision API endpoint, e.g. OpenAI-compatible /v1/chat/completions
VISION_API_URL=https://your-vision-endpoint.example.com/v1/chat/completions
# Keep secret, bridge startup log will only print set/missing
VISION_API_KEY=your_api_key_here
# Must be a model with image/vision capability
VISION_MODEL=your_vision_model_here

# QQ / NapCat
NAPCAT_HTTP=http://127.0.0.1:3001
NAPCAT_TOKEN=hajimi
ALLOWED_PRIVATE_USER=273007866
OWNER_QQ=273007866
OWNER_NAME=Candace
AI_CMD=/home/cancade/.local/bin/ocai

# Scheduler
SCHEDULER_TICK_SECONDS=15
SLEEP_REMINDER_TIME=01:30
TOMORROW_SCHEDULE_TIME=23:30
SLEEP_REMINDER_TEXT=该睡觉了，别熬太晚。
PRIVATE_CONTEXT_WINDOW_SECONDS=1800
PRIVATE_CONTEXT_SOFT_LIMIT_SECONDS=3600
PRIVATE_COMPACT_MAX_TURNS=2
PRIVATE_COMPACT_MAX_CHARS=400
DEFAULT_WEATHER_CITY=Zhuhai
WEATHER_API_TIMEOUT_SECONDS=8

# Quick local testing: set to minutes after service startup, 0 means disabled
SLEEP_REMINDER_TEST_DELAY_MINUTES=0
TOMORROW_SCHEDULE_TEST_DELAY_MINUTES=0
